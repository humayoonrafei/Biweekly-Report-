# ===========================================
# Agentic AI Orchestrator — Environment Config
# ===========================================
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.

# --- LLM API Keys ---
# Uncomment and fill in the one(s) you plan to use:

# Anthropic (Claude Opus / Sonnet)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google (Gemini 1.5 Pro / 2.0)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI (optional fallback)
# OPENAI_API_KEY=your_openai_api_key_here

# --- Model Selection ---
# Which model the orchestrator should use by default
DEFAULT_MODEL=gemini-1.5-pro
# Alternatives: claude-opus-4-20250514, claude-sonnet-4-20250514, gpt-4o

# --- Google Sheets API ---
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_NAME=biweeklyReport

# --- Column Mapping (adjust for different spreadsheet layouts) ---
# Change these to match your school's spreadsheet structure
STUDENT_NAME_COL=B
STUDENT_COMMENT_COL=C
PARENT_COMMENT_COL=D
GRADE_COL=E
TARDIES_COL=AJ
ABSENCES_COL=AK
HEADER_ROW=3
DATA_START_ROW=4

# --- MCP Configuration ---
CHROME_DEBUGGER_PORT=9222
